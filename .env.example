# StockAI 環境配置範例
# 複製此文件為 .env 並填寫實際值

# ===== 服務端口 =====
PORT=3007
NODE_ENV=development

# ===== AI Gateway 整合 =====
GATEWAY_URL=http://127.0.0.1:3005
GATEWAY_API_PATH=/api/query
APP_ID=stock-ai

# ===== 認證（重要：生產環境必須設置！）=====
# JWT 密鑰：至少 32 字元的隨機字符串，請使用 openssl rand -base64 48 生成
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# ===== CORS 跨域 =====
# 生產環境：填寫前端域名，多個用逗號分隔
# 開發環境：留空表示允許所有來源
CORS_ORIGINS=

# ===== 第三方 API（可選）=====
# Alpha Vantage（免費 key 每天 25 次請求，付費解鎖更多）
ALPHA_VANTAGE_KEY=demo
