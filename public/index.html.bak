<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>StockAI - 美股投顧助手</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #1a1a2e;
      --accent: #00C853;
      --accent-rgb: 0, 200, 83;
      --accent-light: #69F0AE;
      --red: #FF5252;
      --blue: #448AFF;
      --bg: #f5f7fa;
      --card: #ffffff;
      --text: #1a1a2e;
      --text-secondary: #6b7280;
      --border: #e5e7eb;
      --shadow: 0 4px 20px rgba(0,0,0,0.06);
      --shadow-lg: 0 8px 40px rgba(0,0,0,0.1);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    body {
      font-family: 'Noto Sans TC', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      padding-bottom: 100px;
    }

    /* Header */
    .header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      padding: 16px 20px;
      z-index: 100;
      border-bottom: 1px solid var(--border);
    }
    .header-inner {
      max-width: 600px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo {
      font-size: 20px;
      font-weight: 700;
    }
    .logo span { color: var(--accent); }
    .logo-sub { font-size: 12px; color: var(--text-secondary); }

    /* Main */
    .main {
      max-width: 600px;
      margin: 0 auto;
      padding: 80px 20px 20px;
    }

    /* Hero */
    .hero {
      text-align: center;
      padding: 32px 0 24px;
    }
    .hero-emoji { font-size: 56px; margin-bottom: 12px; }
    .hero-title { font-size: 24px; font-weight: 600; margin-bottom: 6px; }
    .hero-subtitle { font-size: 14px; color: var(--text-secondary); }

    /* Search */
    .search-container { margin-bottom: 20px; }
    .search-box {
      display: flex;
      gap: 10px;
    }
    .ticker-input {
      flex: 1;
      padding: 14px 16px;
      font-size: 16px;
      border: 2px solid var(--border);
      border-radius: 12px;
      background: var(--card);
      outline: none;
      font-family: inherit;
      text-transform: uppercase;
    }
    .ticker-input:focus { border-color: var(--accent); }
    .search-btn {
      width: 52px;
      height: 52px;
      border: none;
      background: var(--accent);
      border-radius: 12px;
      font-size: 20px;
      cursor: pointer;
    }
    .search-btn:active { transform: scale(0.95); }

    /* Quick Chips */
    .quick-chips {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding: 4px 0 12px;
      scrollbar-width: none;
    }
    .quick-chips::-webkit-scrollbar { display: none; }
    .chip {
      flex-shrink: 0;
      padding: 8px 14px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      font-size: 13px;
      color: var(--text-secondary);
      cursor: pointer;
    }
    .chip:active { transform: scale(0.96); }

    /* Analysis Type */
    .analysis-types {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-bottom: 20px;
    }
    .type-btn {
      padding: 14px 12px;
      background: var(--card);
      border: 2px solid var(--border);
      border-radius: 12px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: inherit;
    }
    .type-btn:active { transform: scale(0.98); }
    .type-btn.active {
      border-color: var(--accent);
      background: rgba(var(--accent-rgb), 0.08);
      color: var(--accent);
    }
    .type-icon { font-size: 18px; }

    /* Loading */
    .loading {
      display: none;
      text-align: center;
      padding: 48px 20px;
    }
    .loading.show { display: block; }
    .spinner {
      width: 40px;
      height: 40px;
      border: 3px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 16px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Result */
    .result-view { display: none; }
    .result-view.show { display: block; }

    .result-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }
    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      color: var(--accent);
      background: none;
      border: none;
      cursor: pointer;
    }
    .ticker-badge {
      padding: 6px 12px;
      background: var(--primary);
      color: #fff;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
    }

    .result-card {
      background: var(--card);
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 16px;
      box-shadow: var(--shadow);
    }
    .result-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 12px;
      color: var(--accent);
    }
    .result-content {
      font-size: 14px;
      line-height: 1.8;
      color: var(--text);
      white-space: pre-wrap;
    }

    /* Recommendation */
    .recommendation {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 20px;
      background: linear-gradient(135deg, var(--primary), #2d2d4a);
      border-radius: 16px;
      margin-bottom: 20px;
    }
    .rec-icon { font-size: 36px; }
    .rec-label { font-size: 13px; opacity: 0.8; }
    .rec-value { font-size: 24px; font-weight: 700; }
    .rec-buy { color: #4ADE80; }
    .rec-hold { color: #FBBF24; }
    .rec-sell { color: #F87171; }
    .rec-watch { color: #60A5FA; }

    /* Actions */
    .action-row {
      display: flex;
      gap: 12px;
    }
    .action-btn {
      flex: 1;
      padding: 12px;
      border: none;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-family: inherit;
    }
    .action-btn.secondary { background: var(--bg); color: var(--text); }
    .action-btn.primary { background: var(--accent); color: #fff; }

    /* History Section */
    .section { margin-top: 32px; }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
    }
    .section-title { font-size: 16px; font-weight: 600; }
    .section-more { font-size: 13px; color: var(--accent); background: none; border: none; cursor: pointer; }

    .history-list { display: flex; flex-direction: column; gap: 10px; }
    .history-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px;
      background: var(--card);
      border-radius: 12px;
      box-shadow: var(--shadow);
      cursor: pointer;
    }
    .history-ticker {
      width: 48px;
      height: 48px;
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }
    .history-info { flex: 1; min-width: 0; }
    .history-title { font-size: 14px; font-weight: 600; }
    .history-type { font-size: 12px; color: var(--text-secondary); }
    .history-arrow { font-size: 18px; color: var(--border); }

    /* Empty */
    .empty {
      text-align: center;
      padding: 32px 20px;
      color: var(--text-secondary);
    }
    .empty-icon { font-size: 40px; margin-bottom: 8px; }
    .empty-text { font-size: 13px; }

    /* Chat */
    .chat-view { display: none; }
    .chat-view.show { display: block; }

    .chat-messages {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 20px;
    }
    .chat-msg {
      max-width: 85%;
      padding: 14px 16px;
      border-radius: 16px;
      font-size: 14px;
      line-height: 1.6;
    }
    .chat-msg.user {
      align-self: flex-end;
      background: var(--accent);
      color: #fff;
    }
    .chat-msg.ai {
      align-self: flex-start;
      background: var(--card);
      box-shadow: var(--shadow);
    }

    .chat-input-box {
      display: flex;
      gap: 10px;
      position: sticky;
      bottom: 0;
      background: var(--bg);
      padding: 12px 0;
    }
    .chat-input {
      flex: 1;
      padding: 14px 16px;
      font-size: 15px;
      border: 2px solid var(--border);
      border-radius: 24px;
      background: var(--card);
      outline: none;
      font-family: inherit;
    }
    .chat-send {
      width: 48px;
      height: 48px;
      border: none;
      background: var(--accent);
      border-radius: 50%;
      font-size: 18px;
      cursor: pointer;
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 90px;
      left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: var(--primary);
      color: #fff;
      padding: 12px 24px;
      border-radius: 24px;
      font-size: 14px;
      opacity: 0;
      transition: all 0.3s;
      z-index: 300;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* Disclaimer */
    .disclaimer {
      margin-top: 24px;
      padding: 16px;
      background: #FFF3E0;
      border-radius: 12px;
      font-size: 12px;
      color: #E65100;
      line-height: 1.6;
    }

    /* Bottom Nav */
    .bottom-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(20px);
      display: flex;
      justify-content: space-around;
      padding: 10px 0;
      padding-bottom: max(10px, env(safe-area-inset-bottom));
      border-top: 1px solid var(--border);
      z-index: 100;
    }
    .nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      padding: 8px 20px;
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 10px;
      cursor: pointer;
    }
    .nav-item.active { color: var(--accent); }
    .nav-item .icon { font-size: 22px; }

    .page { display: none; }
    .page.active { display: block; }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-inner">
      <div>
        <div class="logo">Stock<span>AI</span></div>
        <div class="logo-sub">美股 AI 投顧助手</div>
      </div>
    </div>
  </header>

  <!-- Home Page -->
  <main class="main page active" id="homePage">
    <div class="hero">
      <div class="hero-emoji">📈</div>
      <h1 class="hero-title">分析你的投資</h1>
      <p class="hero-subtitle">輸入股票代碼，獲得專業分析</p>
    </div>

    <!-- Search -->
    <div class="search-container">
      <div class="search-box">
        <input type="text" class="ticker-input" id="tickerInput" placeholder="輸入代碼，如：AAPL">
        <button class="search-btn" id="searchBtn">🔍</button>
      </div>
    </div>

    <!-- Quick Chips -->
    <div class="quick-chips">
      <span class="chip" data-ticker="AAPL">AAPL 蘋果</span>
      <span class="chip" data-ticker="NVDA">NVDA 輝達</span>
      <span class="chip" data-ticker="MSFT">MSFT 微軟</span>
      <span class="chip" data-ticker="TSLA">TSLA 特斯拉</span>
      <span class="chip" data-ticker="META">META</span>
      <span class="chip" data-ticker="GOOGL">GOOGL</span>
    </div>

    <!-- Analysis Types -->
    <div class="analysis-types">
      <button class="type-btn active" data-type="overview">
        <span class="type-icon">📊</span>全面分析
      </button>
      <button class="type-btn" data-type="technical">
        <span class="type-icon">📈</span>技術面
      </button>
      <button class="type-btn" data-type="fundamental">
        <span class="type-icon">💰</span>基本面
      </button>
      <button class="type-btn" data-type="compare">
        <span class="type-icon">⚖️</span>比較分析
      </button>
      <button class="type-btn" data-type="risk">
        <span class="type-icon">⚠️</span>風險評估
      </button>
      <button class="type-btn" data-type="signal">
        <span class="type-icon">🎯</span>買賣信號
      </button>
    </div>

    <!-- Loading -->
    <div class="loading" id="loading">
      <div class="spinner"></div>
      <div class="loading-text">資深分析師正在分析...</div>
    </div>

    <!-- Result -->
    <div class="result-view" id="resultView"></div>

    <!-- History -->
    <div class="section">
      <div class="section-header">
        <h2 class="section-title">最近分析</h2>
      </div>
      <div class="history-list" id="historyList"></div>
    </div>

    <div class="disclaimer">
      ⚠️ 風險提示：本系統提供的分析和建議僅供參考，不構成任何投資建議。投資有風險，請自行承擔後果。
    </div>
  </main>

  <!-- Chat Page -->
  <main class="main page" id="chatPage">
    <div class="section-header" style="margin-bottom: 16px;">
      <h2 class="section-title">💬 提問分析師</h2>
    </div>
    <div class="chat-messages" id="chatMessages">
      <div class="chat-msg ai">
        你好！我是 StockAI 投顧助手。有任何關於美股的問題，歡迎隨時問我！
      </div>
    </div>
    <div class="chat-input-box">
      <input type="text" class="chat-input" id="chatInput" placeholder="問關於股票、投資的問題...">
      <button class="chat-send" id="chatSend">➤</button>
    </div>
  </main>

  <!-- Portfolio Page -->
  <main class="main page" id="portfolioPage">
    <div class="hero">
      <div class="hero-emoji">💼</div>
      <h1 class="hero-title">我的持倉</h1>
    </div>
    <div class="search-container">
      <div class="search-box">
        <input type="text" class="ticker-input" id="portfolioInput" placeholder="輸入持倉，如：AAPL,MSFT,GOOGL">
        <button class="search-btn" id="analyzePortfolioBtn">📋</button>
      </div>
    </div>
    <div id="portfolioResult"></div>
  </main>

  <!-- Bottom Nav -->
  <nav class="bottom-nav">
    <button class="nav-item active" data-page="home"><span class="icon">🏠</span>首頁</button>
    <button class="nav-item" data-page="chat"><span class="icon">💬</span>提問</button>
    <button class="nav-item" data-page="portfolio"><span class="icon">💼</span>持倉</button>
    <button class="nav-item" data-page="watchlist"><span class="icon">⭐</span>自選</button>
  </nav>

  <!-- Watchlist Page -->
  <main class="main page" id="watchlistPage">
    <div class="hero">
      <div class="hero-emoji">⭐</div>
      <h1 class="hero-title">我的自選股</h1>
      <p class="hero-subtitle">點擊股票添加/移除自選</p>
    </div>
    <div id="watchlistCards"></div>
  </main>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <script>
    // State
    let currentType = 'overview';
    let currentTicker = '';
    let history = JSON.parse(localStorage.getItem('stock_history') || '[]');
    let chatHistory = [];
    let watchlist = JSON.parse(localStorage.getItem('stock_watchlist') || '[]');

    // Elements
    const tickerInput = document.getElementById('tickerInput');
    const searchBtn = document.getElementById('searchBtn');
    const loading = document.getElementById('loading');
    const resultView = document.getElementById('resultView');
    const historyList = document.getElementById('historyList');
    const toast = document.getElementById('toast');

    // Toast
    function showToast(msg) {
      toast.textContent = msg;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2500);
    }

    // Page Navigation
    function showPage(page) {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
      document.getElementById(page + 'Page').classList.add('active');
      document.querySelector(`.nav-item[data-page="${page}"]`)?.classList.add('active');
      if (page === 'watchlist') renderWatchlist();
    }

    // Analysis Type
    document.querySelectorAll('.type-btn').forEach(btn => {
      btn.onclick = () => {
        document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentType = btn.dataset.type;
      };
    });

    // Search
    async function analyze() {
      const ticker = tickerInput.value.trim().toUpperCase();
      if (!ticker) {
        showToast('請輸入股票代碼');
        return;
      }

      currentTicker = ticker;
      loading.classList.add('show');
      resultView.classList.remove('show');

      // 逐步反饋
      loading.querySelector('.loading-text').textContent = '正在獲取股價數據...';

      try {
        // Step 1: 獲取報價
        const quoteRes = await fetch('/api/quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ticker })
        });
        const quote = await quoteRes.json();
        
        // 顯示報價卡片（即使分析還沒完成）
        if (quote && quote.success) {
          renderQuoteOnly(ticker, quote);
        }

        // Step 2: 開始分析
        loading.querySelector('.loading-text').textContent = '🤖 AI 分析師正在分析中...';
        
        const res = await fetch('/api/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ticker, type: currentType })
        });

        const data = await res.json();

        if (!data.success) throw new Error(data.error || '分析失敗');

        renderResult(ticker, currentType, data.content, quote);
        addToHistory(ticker, currentType);
        showToast('分析完成！');

      } catch (error) {
        showToast(error.message || '發生錯誤');
      } finally {
        loading.classList.remove('show');
      }
    }

    // 只顯示報價（分析過程中）
    function renderQuoteOnly(ticker, quote) {
      if (!quote || !quote.success) return;
      
      const isUp = quote.change >= 0;
      const quoteHtml = `
        <div class="result-card" style="background: linear-gradient(135deg, var(--primary), #2d2d4a); color: #fff;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
            <div>
              <div style="font-size:14px;opacity:0.8;">${quote.name}</div>
              <div style="font-size:28px;font-weight:700;">$${quote.price?.toFixed(2) || '-'}</div>
            </div>
            <div style="text-align:right;">
              <div style="font-size:16px;font-weight:600;${isUp ? 'color:#4ADE80' : 'color:#F87171'}">
                ${isUp ? '▲' : '▼'} $${Math.abs(quote.change || 0).toFixed(2)}
              </div>
              <div style="font-size:14px;${isUp ? 'color:#4ADE80' : 'color:#F87171'}">
                (${isUp ? '+' : ''}${(quote.changePercent || 0).toFixed(2)}%)
              </div>
            </div>
          </div>
          <div style="font-size:12px;opacity:0.7;">
            ${quote.note || ''} ${quote.source === 'realtime' ? '✅ 實時數據' : '⚠️ 模擬數據'}
          </div>
        </div>
      `;
      
      // 先顯示報價
      resultView.innerHTML = `
        <div class="result-header">
          <button class="back-btn" onclick="backToHome()">← 返回</button>
          <span class="ticker-badge">${ticker}</span>
        </div>
        ${quoteHtml}
        <div class="loading show" style="background:transparent;">
          <div class="spinner"></div>
          <div class="loading-text">🤖 AI 分析師正在分析中...</div>
        </div>
      `;
      resultView.classList.add('show');
    }

    function renderResult(ticker, type, content, quote) {
      const typeLabels = {
        overview: '全面分析',
        technical: '技術面分析',
        fundamental: '基本面分析',
        compare: '比較分析',
        risk: '風險評估',
        signal: '買賣信號'
      };

      // 格式化數字
      const fmt = n => n ? (typeof n === 'number' ? n.toLocaleString('en-US', { maximumFractionDigits: 2 }) : n) : '-';
      const fmtPrice = n => n ? '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '-';

      // 報價卡片
      let quoteHtml = '';
      if (quote && quote.success) {
        const isUp = quote.change >= 0;
        const changeColor = isUp ? 'var(--red)' : 'var(--blue)'; // 漲是紅色，跌是綠色（美股慣例）
        quoteHtml = `
          <div class="result-card" style="background: linear-gradient(135deg, var(--primary), #2d2d4a); color: #fff;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
              <div>
                <div style="font-size:14px;opacity:0.8;">${quote.name}</div>
                <div style="font-size:28px;font-weight:700;">${fmtPrice(quote.price)}</div>
              </div>
              <div style="text-align:right;">
                <div style="font-size:16px;font-weight:600;${isUp ? 'color:#4ADE80' : 'color:#F87171'}">
                  ${isUp ? '▲' : '▼'} ${fmtPrice(Math.abs(quote.change))}
                </div>
                <div style="font-size:14px;${isUp ? 'color:#4ADE80' : 'color:#F87171'}">
                  (${isUp ? '+' : ''}${quote.changePercent.toFixed(2)}%)
                </div>
              </div>
            </div>
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;font-size:12px;opacity:0.8;">
              <div>開盤: ${fmtPrice(quote.open)}</div>
              <div>最高: ${fmtPrice(quote.high)}</div>
              <div>最低: ${fmtPrice(quote.low)}</div>
              <div>成交量: ${(quote.volume/1000000).toFixed(1)}M</div>
              <div>52週高: ${fmtPrice(quote.fiftyTwoWeekHigh)}</div>
              <div>52週低: ${fmtPrice(quote.fiftyTwoWeekLow)}</div>
              <div>市值: ${(quote.marketCap/1e12).toFixed(1)}T</div>
              <div>本益比: ${quote.peRatio?.toFixed(1) || '-'}</div>
            </div>
          </div>
        `;
      }

      // 簡單的建議判斷
      let recommendation = null;
      const lowerContent = content.toLowerCase();
      if (lowerContent.includes('買入') || lowerContent.includes('建議買入') || lowerContent.includes('bullish') || lowerContent.includes('建議增持') || lowerContent.includes('適合買入') || lowerContent.includes('可以買') || lowerContent.includes('分批買') || lowerContent.includes('輕倉')) {
        recommendation = { icon: '🚀', label: '建議買入', class: 'rec-buy' };
      } else if (lowerContent.includes('賣出') || lowerContent.includes('建議賣出') || lowerContent.includes('bearish') || lowerContent.includes('建議減持') || lowerContent.includes('建議清倉') || lowerContent.includes('盡快賣')) {
        recommendation = { icon: '⚠️', label: '建議賣出', class: 'rec-sell' };
      } else if (lowerContent.includes('持有') || lowerContent.includes('觀望') || lowerContent.includes('中性') || lowerContent.includes('繼續持有')) {
        recommendation = { icon: '⏸️', label: '建議持有', class: 'rec-hold' };
      }

      const recHtml = recommendation ? `
        <div class="recommendation">
          <span class="rec-icon">${recommendation.icon}</span>
          <div>
            <div class="rec-label">投資建議</div>
            <div class="rec-value ${recommendation.class}">${recommendation.label}</div>
          </div>
        </div>
      ` : '';

      resultView.innerHTML = `
        <div class="result-header">
          <button class="back-btn" onclick="backToHome()">← 返回</button>
          <span class="ticker-badge">${ticker}</span>
        </div>
        ${quoteHtml}
        ${recHtml}
        <div class="result-card">
          <div class="result-title">${typeLabels[type] || '分析結果'}</div>
          <div class="result-content">${content}</div>
        </div>
        <div class="action-row">
          <button class="action-btn secondary" onclick="copyResult()">📋 複製</button>
          <button class="action-btn primary" onclick="askMore()">💬 追問</button>
        </div>
      `;

      resultView.classList.add('show');
      addWatchlistBtn();
    }

    function backToHome() {
      resultView.classList.remove('show');
      renderHistory();
    }

    function copyResult() {
      const content = document.querySelector('.result-content').textContent;
      navigator.clipboard.writeText(content);
      showToast('已複製');
    }

    function askMore() {
      showPage('chat');
    }

    // History
    function addToHistory(ticker, type) {
      history = [{ ticker, type, time: Date.now() }, ...history.filter(h => h.ticker !== ticker)].slice(0, 10);
      localStorage.setItem('stock_history', JSON.stringify(history));
    }

    function renderHistory() {
      if (!history.length) {
        historyList.innerHTML = '<div class="empty"><div class="empty-icon">📊</div><div class="empty-text">開始分析你的第一支股票</div></div>';
        return;
      }
      const typeLabels = { overview: '全面', technical: '技術', fundamental: '基本面', compare: '比較', risk: '風險', signal: '信號' };
      historyList.innerHTML = history.map(h => `
        <div class="history-item" onclick="loadHistory('${h.ticker}', '${h.type}')">
          <div class="history-ticker">${h.ticker.substring(0, 4)}</div>
          <div class="history-info">
            <div class="history-title">${h.ticker}</div>
            <div class="history-type">${typeLabels[h.type] || h.type}</div>
          </div>
          <div class="history-arrow">›</div>
        </div>
      `).join('');
    }

    // ========== 自選股功能 ==========
    // watchlist 和 priceAlerts 已在上面聲明

    function toggleWatchlist(ticker) {
      const idx = watchlist.indexOf(ticker);
      if (idx > -1) {
        watchlist.splice(idx, 1);
        showToast('已從自選移除');
      } else {
        watchlist.push(ticker);
        showToast('已添加到自選');
      }
      localStorage.setItem('stock_watchlist', JSON.stringify(watchlist));
      renderWatchlist();
      // 更新结果页面的按钮状态
      const btn = document.querySelector('.watchlist-toggle-btn');
      if (btn) {
        btn.textContent = watchlist.includes(currentTicker) ? '⭐ 已加入自選' : '☆ 加入自選';
        btn.classList.toggle('active', watchlist.includes(currentTicker));
      }
    }

    function setPriceAlert(ticker, price, type) {
      const alert = { ticker, price, type, created: Date.now() };
      priceAlerts.push(alert);
      localStorage.setItem('stock_alerts', JSON.stringify(priceAlerts));
      showToast(`已設置 ${type === 'above' ? '漲破' : '跌至'} $${price} 提醒`);
      renderAlertBtn();
    }

    function showAlertDialog(ticker, currentPrice) {
      const dialog = document.createElement('div');
      dialog.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:500;display:flex;align-items:center;justify-content:center;';
      dialog.innerHTML = `
        <div style="background:#fff;border-radius:16px;padding:24px;width:85%;max-width:320px;">
          <div style="font-size:18px;font-weight:600;margin-bottom:16px;">設置價格提醒</div>
          <div style="font-size:14px;color:var(--text-secondary);margin-bottom:16px;">${ticker} 當前價格: $${currentPrice.toFixed(2)}</div>
          <input type="number" id="alertPrice" placeholder="提醒價格" step="0.01" value="${currentPrice.toFixed(2)}"
            style="width:100%;padding:12px;border:2px solid var(--border);border-radius:10px;font-size:16px;margin-bottom:12px;">
          <div style="display:flex;gap:10px;margin-bottom:16px;">
            <button onclick="setPriceAlert('${ticker}', document.getElementById('alertPrice').value, 'above')"
              style="flex:1;padding:12px;background:var(--accent);color:#fff;border:none;border-radius:10px;font-size:14px;">
              🔔 漲破提醒
            </button>
            <button onclick="setPriceAlert('${ticker}', document.getElementById('alertPrice').value, 'below')"
              style="flex:1;padding:12px;background:var(--red);color:#fff;border:none;border-radius:10px;font-size:14px;">
              📉 跌至提醒
            </button>
          </div>
          <button onclick="this.closest('[style*=\'position:fixed\']').remove()"
            style="width:100%;padding:12px;background:var(--bg);border:none;border-radius:10px;font-size:14px;">取消</button>
        </div>
      `;
      document.body.appendChild(dialog);
    }

    function renderAlertBtn() {
      const actionRow = document.querySelector('.action-row');
      if (!actionRow || !currentTicker) return;
      
      // 檢查是否有設置過提醒
      const hasAlert = priceAlerts.some(a => a.ticker === currentTicker);
      const alertHtml = hasAlert ? '' : `<button class="action-btn secondary" onclick="showAlertDialog('${currentTicker}', ${document.querySelector('.result-card')?.textContent?.match(/\$\d+\.\d+/)?.[0]?.replace('$','') || 0})">🔔 設置提醒</button>`;
      
      // 在現有按鈕後添加提醒按鈕
      if (!document.querySelector('.alert-btn')) {
        actionRow.innerHTML += `<button class="action-btn secondary alert-btn" onclick="showAlertDialog('${currentTicker}', ${document.querySelector('.result-card')?.textContent?.match(/\$\d+\.\d+/)?.[0]?.replace('$','') || 0})">🔔 價格提醒</button>`;
      }
    }

    async function renderWatchlist() {
      const container = document.getElementById('watchlistCards');
      if (!watchlist.length) {
        container.innerHTML = '<div class="empty"><div class="empty-icon">⭐</div><div class="empty-text">在首頁分析股票後，點擊加入自選</div></div>';
        return;
      }

      container.innerHTML = '<div class="loading show"><div class="spinner"></div></div>';

      try {
        const res = await fetch('/api/quotes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tickers: watchlist })
        });
        const data = await res.json();

        if (!data.success) throw new Error('獲取失敗');

        // 檢查價格提醒
        priceAlerts.forEach(alert => {
          const quote = data.quotes.find(q => q.ticker === alert.ticker && q.success);
          if (quote) {
            if (alert.type === 'above' && quote.price >= alert.price) {
              showToast(`🔔 ${alert.ticker} 漲破 $${alert.price}！`);
            } else if (alert.type === 'below' && quote.price <= alert.price) {
              showToast(`🔔 ${alert.ticker} 跌至 $${alert.price}！`);
            }
          }
        });

        container.innerHTML = data.quotes.map(q => {
          if (!q.success) return '';
          const isUp = q.change >= 0;
          return `
            <div class="result-card" onclick="loadFromWatchlist('${q.ticker}')" style="cursor:pointer">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <div>
                  <div style="font-size:18px;font-weight:700;">${q.ticker}</div>
                  <div style="font-size:13px;color:var(--text-secondary);">${q.name}</div>
                </div>
                <div style="text-align:right;">
                  <div style="font-size:18px;font-weight:600;">$${q.price.toFixed(2)}</div>
                  <div style="font-size:13px;${isUp ? 'color:var(--red)' : 'color:var(--blue)'}">
                    ${isUp ? '▲' : '▼'} ${q.change >= 0 ? '+' : ''}${q.changePercent.toFixed(2)}%
                  </div>
                </div>
              </div>
            </div>
          `;
        }).join('');

      } catch (error) {
        container.innerHTML = '<div class="empty"><div class="empty-icon">❌</div><div class="empty-text">載入失敗</div></div>';
      }
    }

    function loadFromWatchlist(ticker) {
      tickerInput.value = ticker;
      analyze();
    }

    // 在结果页面添加自选按钮
    function addWatchlistBtn() {
      if (!currentTicker) return;
      const actionRow = document.querySelector('.action-row');
      if (actionRow) {
        const isIn = watchlist.includes(currentTicker);
        actionRow.innerHTML = `
          <button class="action-btn secondary watchlist-toggle-btn" onclick="toggleWatchlist('${currentTicker}')">
            ${isIn ? '⭐ 已加入自選' : '☆ 加入自選'}
          </button>
          <button class="action-btn secondary" onclick="copyResult()">📋 複製</button>
          <button class="action-btn primary" onclick="askMore()">💬 追問</button>
        `;
      }
    }

    // ========== 投資組合功能 ==========
    let portfolio = JSON.parse(localStorage.getItem('stock_portfolio') || '[]');

    function addToPortfolio(ticker, shares, buyPrice) {
      const existing = portfolio.find(p => p.ticker === ticker);
      if (existing) {
        const totalShares = existing.shares + shares;
        const totalCost = existing.shares * existing.buyPrice + shares * buyPrice;
        existing.shares = totalShares;
        existing.buyPrice = totalCost / totalShares;
      } else {
        portfolio.push({ ticker, shares, buyPrice, date: Date.now() });
      }
      localStorage.setItem('stock_portfolio', JSON.stringify(portfolio));
      showToast(`已添加 ${ticker} ${shares} 股 @ $${buyPrice}`);
    }

    function showAddPortfolioDialog() {
      if (!currentTicker) {
        showToast('請先分析一支股票');
        return;
      }
      
      const currentPrice = document.querySelector('.result-card')?.textContent?.match(/\$\d+\.\d+/)?.[0]?.replace('$', '') || 0;
      
      const dialog = document.createElement('div');
      dialog.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:500;display:flex;align-items:center;justify-content:center;';
      dialog.innerHTML = `
        <div style="background:#fff;border-radius:16px;padding:24px;width:85%;max-width:320px;">
          <div style="font-size:18px;font-weight:600;margin-bottom:16px;">添加持倉</div>
          <div style="font-size:14px;color:var(--text-secondary);margin-bottom:16px;">${currentTicker} 當前價格: $${currentPrice}</div>
          <input type="number" id="portfolioShares" placeholder="股數" 
            style="width:100%;padding:12px;border:2px solid var(--border);border-radius:10px;font-size:16px;margin-bottom:12px;">
          <input type="number" id="portfolioPrice" placeholder="買入價格" step="0.01" value="${currentPrice}"
            style="width:100%;padding:12px;border:2px solid var(--border);border-radius:10px;font-size:16px;margin-bottom:16px;">
          <button onclick="doAddPortfolio()" 
            style="width:100%;padding:14px;background:var(--accent);color:#fff;border:none;border-radius:10px;font-size:16px;font-weight:600;">
            添加到持倉
          </button>
          <button onclick="this.closest('[style*=\'position:fixed\']').remove()"
            style="width:100%;padding:12px;background:var(--bg);border:none;border-radius:10px;font-size:14px;margin-top:10px;">取消</button>
        </div>
      `;
      document.body.appendChild(dialog);
      
      window.doAddPortfolio = function() {
        const shares = parseFloat(document.getElementById('portfolioShares').value);
        const price = parseFloat(document.getElementById('portfolioPrice').value);
        if (shares > 0 && price > 0) {
          addToPortfolio(currentTicker, shares, price);
          dialog.remove();
        } else {
          showToast('請輸入有效的股數和價格');
        }
      };
    }

    async function renderPortfolio() {
      const container = document.getElementById('portfolioResult');
      if (!portfolio.length) {
        container.innerHTML = `
          <div class="empty">
            <div class="empty-icon">💼</div>
            <div class="empty-text">還沒有持倉，點擊下方按鈕添加</div>
          </div>
          <button class="action-btn primary" onclick="showAddPortfolioDialog()" style="margin-top:16px;">
            ➕ 添加持倉
          </button>
        `;
        return;
      }

      container.innerHTML = '<div class="loading show"><div class="spinner"></div></div>';

      try {
        const tickers = portfolio.map(p => p.ticker);
        const res = await fetch('/api/quotes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tickers })
        });
        const data = await res.json();

        let totalCost = 0;
        let totalValue = 0;

        const html = await Promise.all(portfolio.map(async (p) => {
          const quote = data.quotes.find(q => q.ticker === p.ticker);
          const currentPrice = quote?.price || p.buyPrice;
          const cost = p.shares * p.buyPrice;
          const value = p.shares * currentPrice;
          const profit = value - cost;
          const profitPercent = (profit / cost) * 100;
          
          totalCost += cost;
          totalValue += value;

          const isProfit = profit >= 0;
          
          return `
            <div class="result-card">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                <div>
                  <div style="font-size:18px;font-weight:700;">${p.ticker}</div>
                  <div style="font-size:13px;color:var(--text-secondary);">${p.shares} 股 @ $${p.buyPrice.toFixed(2)}</div>
                </div>
                <div style="text-align:right;">
                  <div style="font-size:18px;font-weight:600;">$${currentPrice.toFixed(2)}</div>
                  <div style="font-size:14px;font-weight:600;${isProfit ? 'color:var(--red)' : 'color:var(--blue)'}">
                    ${isProfit ? '+' : ''}$${profit.toFixed(2)} (${isProfit ? '+' : ''}${profitPercent.toFixed(1)}%)
                  </div>
                </div>
              </div>
              <button onclick="removeFromPortfolio('${p.ticker}')" style="padding:8px 12px;background:var(--bg);border:none;border-radius:8px;font-size:12px;">移除</button>
            </div>
          `;
        }));

        const totalProfit = totalValue - totalCost;
        const totalProfitPercent = (totalProfit / totalCost) * 100;
        const isTotalProfit = totalProfit >= 0;

        container.innerHTML = `
          <div class="result-card" style="background:linear-gradient(135deg,var(--primary),#2d2d4a);color:#fff;">
            <div style="font-size:14px;opacity:0.8;">總資產</div>
            <div style="font-size:28px;font-weight:700;">$${totalValue.toLocaleString('en-US', {minimumFractionDigits:2})}</div>
            <div style="font-size:16px;margin-top:8px;${isTotalProfit ? 'color:#4ADE80' : 'color:#F87171'}">
              ${isTotalProfit ? '+' : ''}$${totalProfit.toFixed(2)} (${isTotalProfit ? '+' : ''}${totalProfitPercent.toFixed(2)}%)
            </div>
          </div>
          ${html.join('')}
          <button class="action-btn primary" onclick="showAddPortfolioDialog()" style="margin-top:16px;">
            ➕ 添加持倉
          </button>
        `;
      } catch (error) {
        container.innerHTML = '<div class="empty"><div class="empty-icon">❌</div><div class="empty-text">載入失敗</div></div>';
      }
    }

    function removeFromPortfolio(ticker) {
      portfolio = portfolio.filter(p => p.ticker !== ticker);
      localStorage.setItem('stock_portfolio', JSON.stringify(portfolio));
      renderPortfolio();
      showToast(`已移除 ${ticker}`);
    }

    function loadHistory(ticker, type) {
      tickerInput.value = ticker;
      document.querySelectorAll('.type-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.type === type);
      });
      currentType = type;
      analyze();
    }

    // Chat
    const chatInput = document.getElementById('chatInput');
    const chatSend = document.getElementById('chatSend');
    const chatMessages = document.getElementById('chatMessages');

    async function sendChat() {
      const msg = chatInput.value.trim();
      if (!msg) return;

      chatMessages.innerHTML += `<div class="chat-msg user">${msg}</div>`;
      chatInput.value = '';
      chatMessages.scrollTop = chatMessages.scrollHeight;

      chatMessages.innerHTML += `<div class="chat-msg ai">思考中...</div>`;
      chatMessages.scrollTop = chatMessages.scrollHeight;

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: [{ role: 'user', content: msg }] })
        });
        const data = await res.json();

        chatMessages.lastElementChild.remove();
        chatMessages.innerHTML += `<div class="chat-msg ai">${data.content}</div>`;
        chatMessages.scrollTop = chatMessages.scrollHeight;

      } catch (error) {
        chatMessages.lastElementChild.remove();
        chatMessages.innerHTML += `<div class="chat-msg ai">發生錯誤，請稍後再試</div>`;
      }
    }

    chatSend.onclick = sendChat;
    chatInput.onkeypress = e => { if (e.key === 'Enter') sendChat(); };

    // Portfolio
    async function analyzePortfolio() {
      const input = document.getElementById('portfolioInput').value.trim();
      if (!input) {
        showToast('請輸入持倉');
        return;
      }

      const resultDiv = document.getElementById('portfolioResult');
      resultDiv.innerHTML = '<div class="loading show"><div class="spinner"></div></div>';

      try {
        const res = await fetch('/api/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ticker: input, type: 'portfolio' })
        });
        const data = await res.json();

        if (!data.success) throw new Error(data.error);

        resultDiv.innerHTML = `
          <div class="result-card">
            <div class="result-title">💼 持倉分析建議</div>
            <div class="result-content">${data.content}</div>
          </div>
        `;

      } catch (error) {
        resultDiv.innerHTML = `<div class="empty"><div class="empty-icon">❌</div><div class="empty-text">${error.message}</div></div>`;
      }
    }

    document.getElementById('analyzePortfolioBtn').onclick = analyzePortfolio;
    
    // Portfolio page load
    const portfolioPage = document.getElementById('portfolioPage');
    const observer = new MutationObserver(() => {
      if (portfolioPage.classList.contains('active')) {
        renderPortfolio();
      }
    });
    observer.observe(portfolioPage, { attributes: true, attributeFilter: ['class'] });

    // Events
    searchBtn.onclick = analyze;
    tickerInput.onkeypress = e => { if (e.key === 'Enter') analyze(); };

    document.querySelectorAll('.nav-item').forEach(btn => {
      btn.onclick = () => showPage(btn.dataset.page);
    });

    document.querySelectorAll('.chip').forEach(chip => {
      chip.onclick = () => {
        tickerInput.value = chip.dataset.ticker;
        analyze();
      };
    });

    // Init
    renderHistory();
  </script>
</body>
</html>

<!-- Watchlist Page -->
  <main class="main page" id="watchlistPage">
    <div class="section-header">
      <h2 class="section-title">⭐ 自選股</h2>
    </div>
    <div id="watchlistResult"></div>
  </main>
